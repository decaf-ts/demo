{
  "name": "@decaf-ts/demo-angular-ionic",
  "version": "0.0.1",
  "author": "Tiago Venceslau",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/decaf-ts/demo.git"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "do-install": "TOKEN=$(cat .token) npm install",
    "update-dependencies": "PREFIX=\"decaf-ts\"; npm ls | grep \"$PREFIX\" | awk -F/ '{print $NF}' | sed 's/@.*//' | xargs -I package npm update @\"$PREFIX\"/package && ng cache clean",
    "ng": "ng",
    "start": "npx rimraf .angular && ng serve --port=8120 --configuration development",
    "server": "npm run start",
    "build": "ng build",
    "watch": "ng build --watch --port=8120 --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "prepare-pr": "npm run repo:pr && npm run lint-fix && npm run build:prod && npm run coverage && npm run docs",
    "repo:init": "codex exec \"$(cat ./.codex/prompts/repo-setup.md)\nbase_path is `./`, initialize the repository\"",
    "repo:setup": "codex exec \"$(cat ./.codex/prompts/repo-setup.md)\nbase_path is ./\"",
    "repo:doc": "codex exec \"$(cat ./.codex/prompts/doc.md) $(cat ./.codex/prompts/bulk-docs.md)\nbase_path is ./\"",
    "repo:tests": "codex exec \"$(cat ./.codex/prompts/bulk-tests.md)\nbase_path is ./ and coverage is 95%\" -s workspace-write",
    "repo:readme": "codex exec \"$(cat ./.codex/prompts/update-readme.md)\nbase_path is ./\"",
    "repo:pr": "npm run repo:doc && npm run repo:tests && npm run repo:readme",
    "sync-codex": "./bin/sync-codex.sh"
  },
  "private": true,
  "dependencies": {
   "@angular-builders/custom-webpack": "^20.0.0",
    "@angular/animations": "^20.3.16",
    "@angular/common": "^20.3.16",
    "@angular/compiler": "^20.3.16",
    "@angular/core": "^20.3.16",
    "@angular/forms": "^20.3.16",
    "@angular/platform-browser": "^20.3.16",
    "@angular/platform-browser-dynamic": "^20.3.16",
    "@angular/router": "^20.3.16",
    "@angular/service-worker": "^20.3.16",
    "@bwip-js/browser": "^4.8.0",
    "@decaf-ts/core": "latest",
    "@decaf-ts/db-decorators": "latest",
    "@decaf-ts/decoration": "latest",
    "@decaf-ts/decorator-validation": "latest",
    "@decaf-ts/for-angular": "latest",
    "@decaf-ts/for-http": "latest",
    "@decaf-ts/injectable-decorators": "latest",
    "@decaf-ts/logging": "latest",
    "@decaf-ts/styles": "latest",
    "@decaf-ts/transactional-decorators": "latest",
    "@decaf-ts/ui-decorators": "latest",
    "@ionic/angular": "^8.7.4",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "@tabler/icons-webfont": "3.31.0",
    "ionicons": "^7.4.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.2.0",
    "@angular-devkit/core": "^20.2.0",
    "@angular-eslint/builder": "^20.2.0",
    "@angular-eslint/schematics": "^20.2.0",
    "@angular/cli": "^20.3.9",
    "@angular/compiler-cli": "^20.3.9",
    "@decaf-ts/cli": "latest",
    "@decaf-ts/utils": "latest",
    "@faker-js/faker": "^10.1.0",
    "@ionic/angular-toolkit": "^12.1.1",
    "@playwright/test": "^1.58.2",
    "@types/jest": "^30.0.0",
    "@types/keycloak-js": "^2.5.4",
    "@types/node": "^24.5.1",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "ajv": "^6.14.0",
    "angular-eslint": "^20.2.0",
    "dotenv": "^17.2.3",
    "dotenv-cli": "^11.0.0",
    "dotenv-expand": "^12.0.3",
    "eslint": "^9.29.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "ffmpeg-static": "^5.2.0",
    "http-server": "^14.1.1",
    "jest": "^29.7.0",
    "jest-html-reporters": "^3.1.7",
    "jest-junit": "^16.0.0",
    "jest-preset-angular": "^14.6.0",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "tslib": "^2.3.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "8.34.1"
  },
  "description": "An Decaf-ts demo project using Angular and Ionic Framework.",
   "overrides": {
    "minimatch": "^10.2.2",
    "test-exclude": "^7.0.1",
    "serialize-javascript": "^7.0.2",
    "fabric-common": {
      "jsrsasign": "^11.1.0"
    },
    "fabric-ca-client": {
      "jsrsasign": "^11.1.0"
    }
  }
}
